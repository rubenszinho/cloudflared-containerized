# Cloudflare Tunnel connector config.
# Per box: cp this to .env.<host-id>, fill in, then `cp .env.<host-id> .env && docker compose up -d`.

# Connector token for this tunnel.
#   Dashboard: Networks > Tunnels > (your tunnel) > configure  -> the --token value
#   or CLI:    cloudflared tunnel token <TUNNEL_ID>
TUNNEL_TOKEN=

# Connector container name. Convention: cloudflared-<host-id>  (e.g. cloudflared-host-001)
CONNECTOR_NAME=cloudflared-host-001

# Optional: shared Docker network the connector + apps join. Default: shared
SHARED_NET=shared
