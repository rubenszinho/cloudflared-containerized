# Cloudflare Tunnel connector config. Copy to .env (gitignored) and fill in.

# Connector token for this tunnel.
#   Dashboard: Networks > Tunnels > (your tunnel) > configure  -> the --token value
#   or CLI:    cloudflared tunnel token <TUNNEL_ID>
TUNNEL_TOKEN=

# Container name for this connector. Convention: cloudflared-<host-id>  (e.g. cloudflared-host-001)
CONNECTOR_NAME=cloudflared-host-001

# How the connector reaches your apps (pick one):
#   APPS="name1 name2"  -> attach exactly these containers to `shared`
#   APPS="auto"          -> attach ALL running containers to `shared` (no list; harmless, DNS-only)
#   APPS=""              -> attach nothing; your app composes join `shared` themselves (cleanest — see README)
APPS=""
